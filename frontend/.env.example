# ── Production-OS Frontend Environment ───────────────────
#
# Local development:
#   Not needed. Vite proxy forwards /api → localhost:3001
#
# Vercel production / preview:
#   Set VITE_API_BASE_URL to the deployed backend URL (including /api path)
#
# VITE_API_BASE_URL=https://your-backend.railway.app/api

# ── Pilot Mode ───────────────────────────────────────────
# Set to "true" for safe rollout. Restricts writes, logs actions.
# Remove or set to "false" for full production access.
#
# VITE_PILOT_MODE=true
