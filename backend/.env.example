# ── Production-OS Backend Environment ────────────────────
#
# Copy this file to backend/.env (gitignored) and fill in the values.
# All variables here are required for local development unless noted.

# ── Supabase ─────────────────────────────────────────────
# Get these from: https://supabase.com/dashboard/project/_/settings/api
SUPABASE_URL=https://kzjdqipcidedkclfijas.supabase.co

# CRITICAL: service_role key (NOT anon key). This bypasses RLS.
# Never commit this. Never expose to frontend.
SUPABASE_SERVICE_KEY=

# ── Anthropic ────────────────────────────────────────────
# Required for: /api/agents/ask, /api/agents/batch/*
# Without it, the LLM agent returns rule-based fallback messages.
# Get from: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# ── Server ───────────────────────────────────────────────
PORT=3001
NODE_ENV=development

# ── Pilot Mode (optional) ────────────────────────────────
# "true" enables policy-based write blocking + audit logging.
# Set to "false" for local development.
PILOT_MODE=false
