{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "buildCommand": "cd backend && npm install"
  },
  "deploy": {
    "runtime": "V2",
    "startCommand": "cd backend && node src/api.js",
    "healthcheckPath": "/api/health",
    "healthcheckTimeout": 30
  }
}
